APP_ENV=development
DATABASE_URL=sqlite:///./data/ai_scientist.db
BACKEND_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_CORS_ALLOW_ORIGIN_REGEX=

# Backend-only secrets. Leave blank to use deterministic fallbacks where supported.
OPENAI_API_KEY=
OPENAI_PARSE_MODEL=gpt-5.4-mini
OPENAI_PLAN_MODEL=gpt-5.5
OPENAI_FALLBACK_MODEL=gpt-5.4-mini
# strict_live uses only live providers; cached_live replays a successful live run; seeded_demo enables deterministic fallback
EVIDENCE_MODE=seeded_demo
STRICT_LIVE_MODE=false
CONSENSUS_MCP_ENABLED=false
CONSENSUS_MCP_BRIDGE_URL=http://127.0.0.1:8765/search
CONSENSUS_MCP_SERVER_URL=https://mcp.consensus.app/mcp
CONSENSUS_BRIDGE_HOST=127.0.0.1
CONSENSUS_BRIDGE_PORT=8765
CONSENSUS_BRIDGE_HOME=
RUN_LIVE_INTEGRATION=false
SEMANTIC_SCHOLAR_API_KEY=
PROTOCOLS_IO_TOKEN=
TAVILY_API_KEY=
